@{
    ViewData["Title"] = "Dashboard";
}

<div class="container-fluid">

    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="stat-box">
                <div class="stat-number">@ViewBag.BuildingsCount</div>
                <div class="stat-label">Buildings</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-box">
                <div class="stat-number">@ViewBag.ApartmentsCount</div>
                <div class="stat-label">Apartments</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-box">
                <div class="stat-number">@ViewBag.TenantsCount</div>
                <div class="stat-label">Tenants</div>
            </div>
        </div>

        <div class="col-md-3">
            <div class="stat-box">
                <div class="stat-number">@ViewBag.PaymentsCount</div>
                <div class="stat-label">Payments</div>
            </div>
        </div>
    </div>

    <div class="row g-4 mt-4">
        <div class="col-md-6">
            <div class="dashboard-card">
                <h5>Payments per Month</h5>
                <canvas id="paymentsChart"></canvas>
            </div>
        </div>

        <div class="col-md-6">
            <div class="dashboard-card">
                <h5>Tenants per Building</h5>
                <canvas id="tenantsChart"></canvas>
            </div>
        </div>
    </div>

</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        const paymentsCtx = document.getElementById('paymentsChart');
        new Chart(paymentsCtx, {
            type: 'bar',
            data: {
                labels: @Html.Raw(ViewBag.PaymentsLabels),
                datasets: [{
                    label: 'Payments',
                    data: @Html.Raw(ViewBag.PaymentsData),
                    backgroundColor: 'rgba(13, 110, 253, 0.5)',
                    borderColor: '#0d6efd',
                    borderWidth: 1
                }]
            }
        });

        const tenantsCtx = document.getElementById('tenantsChart');
        new Chart(tenantsCtx, {
            type: 'pie',
            data: {
                labels: @Html.Raw(ViewBag.TenantsLabels),
                datasets: [{
                    data: @Html.Raw(ViewBag.TenantsData),
                    backgroundColor: [
                        'rgba(13, 110, 253, 0.6)',
                        'rgba(32, 201, 151, 0.6)',
                        'rgba(255, 193, 7, 0.6)',
                        'rgba(220, 53, 69, 0.6)'
                    ]
                }]
            }
        });
    </script>
}