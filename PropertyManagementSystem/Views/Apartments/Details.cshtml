@model PropertyManagementSystem.Core.Entities.Apartment

@{
    ViewData["Title"] = "Apartment Details";
}

<h2>Apartment Details</h2>

<div class="card p-3">
    <dl class="row">
        <dt class="col-sm-3">Number</dt>
        <dd class="col-sm-9">@Model.Number</dd>

        <dt class="col-sm-3">Floor</dt>
        <dd class="col-sm-9">@Model.Floor</dd>

        <dt class="col-sm-3">Building</dt>
        <dd class="col-sm-9">@Model.Building?.Name</dd>
    </dl>
</div>

<p class="mt-3">
    <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    <a class="btn btn-secondary" asp-action="Index">Back to List</a>
</p>