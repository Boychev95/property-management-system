@model PropertyManagementSystem.Core.Entities.Apartment

@{
    ViewData["Title"] = "Create Apartment";
}

<h2>Create Apartment</h2>

<form asp-action="Create" method="post" class="mt-3">

    @Html.ValidationSummary(false, "", new { @class = "text-danger" })

    <div class="mb-3">
        <label asp-for="Number" class="form-label"></label>
        <input asp-for="Number" class="form-control" type="text" />
        <span asp-validation-for="Number" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Floor" class="form-label"></label>
        <input asp-for="Floor" class="form-control" />
        <span asp-validation-for="Floor" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="BuildingId" class="form-label">Building</label>
        <select asp-for="BuildingId" class="form-select" asp-items="ViewBag.Buildings"></select>
        <span asp-validation-for="BuildingId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>