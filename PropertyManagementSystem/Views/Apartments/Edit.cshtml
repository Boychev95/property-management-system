@model PropertyManagementSystem.Core.Entities.Apartment

@{
    ViewData["Title"] = "Edit Apartment";
}

<h2>Edit Apartment</h2>

<form asp-action="Edit" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />

    <div class="mb-3">
        <label asp-for="Number" class="form-label"></label>
        <input asp-for="Number" class="form-control" />
        <span asp-validation-for="Number" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="Floor" class="form-label"></label>
        <input asp-for="Floor" class="form-control" />
        <span asp-validation-for="Floor" class="text-danger"></span>
    </div>

    <div class="mb-3">
        <label asp-for="BuildingId" class="form-label">Building</label>
        <select asp-for="BuildingId" class="form-control" asp-items="ViewBag.Buildings"></select>
        <span asp-validation-for="BuildingId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-warning">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>