@model PropertyManagementSystem.Core.Entities.Apartment

@{
    ViewData["Title"] = "Delete Apartment";
}

<h2>Delete Apartment</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this apartment?
</div>

<div class="card p-3">
    <dl class="row">
        <dt class="col-sm-3">Number</dt>
        <dd class="col-sm-9">@Model.Number</dd>

        <dt class="col-sm-3">Floor</dt>
        <dd class="col-sm-9">@Model.Floor</dd>

        <dt class="col-sm-3">Building</dt>
        <dd class="col-sm-9">@Model.Building?.Name</dd>
    </dl>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>