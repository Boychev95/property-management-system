@model PropertyManagementSystem.Core.Entities.Payment

@{
    ViewData["Title"] = "Delete Payment";
}

<h2>Delete Payment</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this payment?
</div>

<div class="card p-3">
    <dl class="row">
        <dt class="col-sm-3">Tenant</dt>
        <dd class="col-sm-9">@Model.Tenant?.Name</dd>

        <dt class="col-sm-3">Amount</dt>
        <dd class="col-sm-9">@Model.Amount</dd>

        <dt class="col-sm-3">Date</dt>
        <dd class="col-sm-9">@Model.Date.ToShortDateString()</dd>
    </dl>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>