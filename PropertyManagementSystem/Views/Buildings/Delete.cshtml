@model PropertyManagementSystem.Core.Entities.Building

@{
    ViewData["Title"] = "Delete Building";
}

<h2>Delete Building</h2>

<div class="alert alert-danger">
    Are you sure you want to delete this building?
</div>

<div class="card p-3">
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Address</dt>
        <dd class="col-sm-9">@Model.Address</dd>

        <dt class="col-sm-3">Floors</dt>
        <dd class="col-sm-9">@Model.Floors</dd>
    </dl>
</div>

<form asp-action="Delete" method="post" class="mt-3">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>