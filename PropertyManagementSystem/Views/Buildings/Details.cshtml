@model PropertyManagementSystem.Core.Entities.Building

@{
    ViewData["Title"] = "Building Details";
}

<h2>Building Details</h2>

<div class="card p-3">
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Address</dt>
        <dd class="col-sm-9">@Model.Address</dd>

        <dt class="col-sm-3">Floors</dt>
        <dd class="col-sm-9">@Model.Floors</dd>
    </dl>
</div>

<p class="mt-3">
    <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    <a class="btn btn-secondary" asp-action="Index">Back to List</a>
</p>