@model IEnumerable<PropertyManagementSystem.Core.Entities.Building>

@{
    ViewData["Title"] = "Buildings";
}

<h2 class="mb-3">Buildings</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Create New</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Address</th>
            <th>Floors</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.Name</td>
                <td>@b.Address</td>
                <td>@b.Floors</td>
                <td>
                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@b.Id">Details</a>
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@b.Id">Edit</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@b.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>