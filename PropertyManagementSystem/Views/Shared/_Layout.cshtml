@using Microsoft.AspNetCore.Identity
@using PropertyManagementSystem.Core.Entities
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PropertyManagementSystem</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>
<body>
    <div class="app-wrapper d-flex">

        <aside class="app-sidebar">
            <div class="sidebar-header">
                <a asp-controller="Home" asp-action="Index" class="sidebar-brand">
                    <i class="bi bi-grid-3x3-gap-fill me-2"></i>
                    <span>Property Management</span>
                </a>
            </div>

            <nav class="sidebar-nav">
                <ul class="nav flex-column">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>

                    <li class="nav-item mt-2 sidebar-section-title">
                        Management
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Buildings" asp-action="Index">
                            <i class="bi bi-building"></i>
                            <span>Buildings</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Apartments" asp-action="Index">
                            <i class="bi bi-house"></i>
                            <span>Apartments</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Tenants" asp-action="Index">
                            <i class="bi bi-people"></i>
                            <span>Tenants</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Payments" asp-action="Index">
                            <i class="bi bi-credit-card"></i>
                            <span>Payments</span>
                        </a>
                    </li>

                </ul>
            </nav>

            <div class="sidebar-footer">

                @if (User.Identity.IsAuthenticated)
                {
                    var currentUser = await UserManager.GetUserAsync(User);
                    var displayName = currentUser?.FullName ?? "User";

                    <div class="sidebar-user d-flex align-items-center mb-3">
                        <div class="sidebar-avatar">
                            <i class="bi bi-person-circle"></i>
                        </div>
                        <div class="sidebar-user-info">
                            <div class="text-white fw-semibold">@displayName</div>
                        </div>
                    </div>

                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="btn btn-sm w-100 fw-semibold text-white" style="background-color: #000;">
                            <i class="bi bi-box-arrow-right"></i> Logout
                        </button>
                    </form>
                }
                else
                {
                    <div class="d-grid gap-2">
                        <a class="btn btn-sm btn-outline-primary" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right"></i> Login
                        </a>
                        <a class="btn btn-sm btn-success" asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus"></i> Register
                        </a>
                    </div>
                }

            </div>
        </aside>

        <main class="app-main flex-grow-1">
            <header class="app-topbar d-flex align-items-center justify-content-between">
                <div class="app-breadcrumb">
                    @RenderSection("Breadcrumb", required: false)
                </div>
            </header>

            <div class="app-content container-fluid py-4">
                @RenderBody()
            </div>
        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>