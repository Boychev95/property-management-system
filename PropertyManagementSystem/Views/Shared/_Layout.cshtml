<!DOCTYPE html>
<html lang="bg">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Property Management System</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <style>
        body {
            background-color: #f5f6fa;
        }

        .sidebar {
            width: 240px;
            height: 100vh;
            position: fixed;
            left: 0;
            top: 0;
            background-color: #343a40;
            padding-top: 60px;
        }

        .sidebar a {
            color: #ddd;
            padding: 12px 20px;
            display: block;
            text-decoration: none;
            font-size: 15px;
        }

        .sidebar a:hover {
            background-color: #495057;
            color: #fff;
        }

        .content-wrapper {
            margin-left: 240px;
            padding: 30px;
        }

        .navbar-brand {
            font-weight: 600;
        }
    </style>

    @RenderSection("Styles", required: false)
</head>

<body>

    <nav class="navbar navbar-dark bg-dark fixed-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">Property Management</a>

            <div class="d-flex">
                <a class="btn btn-outline-light me-2" href="/Identity/Account/Login">Вход</a>
                <a class="btn btn-success" href="/Identity/Account/Register">Регистрация</a>
            </div>
        </div>
    </nav>

    <div class="sidebar">
        <a href="/Buildings">🏢 Сгради</a>
        <a href="/Apartments">🏠 Апартаменти</a>
        <a href="/Tenants">👥 Наематели</a>
        <a href="/Payments">💳 Плащания</a>
        <hr style="border-color: #555;">
        <a href="/Dashboard">📊 Dashboard</a>
    </div>

    <div class="content-wrapper">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)
</body>
</html>