@using Microsoft.AspNetCore.Identity
@using PropertyManagementSystem.Core.Entities
@inject UserManager<ApplicationUser> UserManager
@inject SignInManager<ApplicationUser> SignInManager

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - PropertyManagementSystem</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <link rel="stylesheet" href="~/css/dashboard.css" />
</head>
<body class="light-theme">
    <div class="app-wrapper d-flex">

        <!-- SIDEBAR -->
        <aside id="sidebar" class="app-sidebar">

            <div class="sidebar-header d-flex justify-content-between align-items-center">
                <a asp-controller="Home" asp-action="Index" class="sidebar-brand text-white">
                    <i class="bi bi-grid-3x3-gap-fill me-2"></i>
                    <span>Property Management</span>
                </a>

                <button id="toggleSidebar" class="btn btn-sm btn-light sidebar-icon-btn">
                    <i class="bi bi-layout-sidebar-inset"></i>
                </button>
            </div>

            <nav class="sidebar-nav">
                <ul class="nav flex-column">

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-speedometer2"></i>
                            <span>Dashboard</span>
                        </a>
                    </li>

                    <li class="nav-item sidebar-section-title">Management</li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Buildings" asp-action="Index">
                            <i class="bi bi-building"></i>
                            <span>Buildings</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Apartments" asp-action="Index">
                            <i class="bi bi-house"></i>
                            <span>Apartments</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Tenants" asp-action="Index">
                            <i class="bi bi-people"></i>
                            <span>Tenants</span>
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Payments" asp-action="Index">
                            <i class="bi bi-credit-card"></i>
                            <span>Payments</span>
                        </a>
                    </li>

                </ul>
            </nav>

            <div class="sidebar-footer">

                @if (SignInManager.IsSignedIn(User))
                {
                    var currentUser = await UserManager.GetUserAsync(User);
                    var fullName = currentUser?.FullName ?? "User";
                    var roles = await UserManager.GetRolesAsync(currentUser);
                    bool isAdmin = roles.Contains("Admin");

                    string initials = "";
                    var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries);
                    initials = parts.Length == 1
                    ? parts[0][0].ToString().ToUpper()
                    : (parts[0][0].ToString() + parts[^1][0].ToString()).ToUpper();

                    <!-- USER BLOCK -->
                    <div class="sidebar-user d-flex align-items-center mb-2 p-2" id="userBlock">
                        <div class="sidebar-avatar me-2">@initials</div>
                        <div class="sidebar-user-info">
                            <div class="user-name">@fullName</div>
                            @if (isAdmin)
                            {
                                <div class="admin-badge">ADMIN</div>
                            }
                        </div>
                    </div>

                    <!-- DROPDOWN INSIDE SIDEBAR -->
                    <div class="user-dropdown" id="userDropdown">
                        <a asp-controller="Account" asp-action="Profile">Profile</a>
                        <a asp-controller="Account" asp-action="Settings">Settings</a>
                        <form asp-controller="Account" asp-action="Logout" method="post">
                            <button type="submit">Logout</button>
                        </form>
                    </div>

                    <!-- THEME -->
                    <button id="themeToggle" class="btn btn-sm btn-light w-100 mb-2 sidebar-icon-btn">
                        <i class="bi bi-brightness-high"></i>
                        <span>Theme</span>
                    </button>

                    <!-- LOGOUT -->
                    <form asp-controller="Account" asp-action="Logout" method="post">
                        <button type="submit" class="btn btn-sm w-100 logout-btn sidebar-icon-btn">
                            <i class="bi bi-power"></i>
                            <span>Logout</span>
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="btn btn-sm btn-light w-100 mb-2 sidebar-icon-btn">
                        <i class="bi bi-box-arrow-in-right"></i>
                        <span>Login</span>
                    </a>

                    <a asp-controller="Account" asp-action="Register" class="btn btn-sm btn-light w-100 sidebar-icon-btn">
                        <i class="bi bi-person-plus"></i>
                        <span>Register</span>
                    </a>
                }
            </div>
        </aside>

        <!-- MAIN CONTENT -->
        <main class="app-main flex-grow-1">
            <header class="app-topbar d-flex align-items-center justify-content-between">
                <div>@RenderSection("Breadcrumb", required: false)</div>
            </header>

            <div class="app-content container-fluid py-4">
                @RenderBody()
            </div>
        </main>

    </div>

    <script src="~/js/dashboard.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>