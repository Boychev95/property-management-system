@model PropertyManagementSystem.Core.Entities.Tenant

@{
    ViewData["Title"] = "Tenant Details";
}

<h2>Tenant Details</h2>

<div class="card p-3">
    <dl class="row">
        <dt class="col-sm-3">Name</dt>
        <dd class="col-sm-9">@Model.Name</dd>

        <dt class="col-sm-3">Phone</dt>
        <dd class="col-sm-9">@Model.Phone</dd>

        <dt class="col-sm-3">Email</dt>
        <dd class="col-sm-9">@Model.Email</dd>

        <dt class="col-sm-3">Apartment</dt>
        <dd class="col-sm-9">@Model.Apartment?.Number</dd>
    </dl>
</div>

<p class="mt-3">
    <a class="btn btn-warning" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
    <a class="btn btn-secondary" asp-action="Index">Back to List</a>
</p>