@model IEnumerable<PropertyManagementSystem.Core.Entities.Tenant>

@{
    ViewData["Title"] = "Tenants";
}

<h2 class="mb-3">Tenants</h2>

<p>
    <a class="btn btn-primary" asp-action="Create">Create New</a>
</p>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Phone</th>
            <th>Email</th>
            <th>Apartment</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var t in Model)
        {
            <tr>
                <td>@t.Name</td>
                <td>@t.Phone</td>
                <td>@t.Email</td>
                <td>@t.Apartment?.Number</td>
                <td>
                    <a class="btn btn-sm btn-info" asp-action="Details" asp-route-id="@t.Id">Details</a>
                    <a class="btn btn-sm btn-warning" asp-action="Edit" asp-route-id="@t.Id">Edit</a>
                    <a class="btn btn-sm btn-danger" asp-action="Delete" asp-route-id="@t.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>